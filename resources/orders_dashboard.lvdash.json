              {
                "name": "main_query",
                "query": {
                  "datasetName": "ds_orders",
                  "fields": [
                    {
                      "name": "total_value",
                      "expression": "SUM(`total_value`)"
                    }
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 2,
              "widgetType": "counter",
              "encodings": {
                "value": {
                  "fieldName": "total_value",
                  "displayName": "Total Value"
                }
              },
              "frame": {
